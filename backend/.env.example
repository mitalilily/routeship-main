# Public backend origin used for platform webhook registration.
# Must be HTTPS in production and must not include /api.
API_URL=https://api.shiplifi.com

# Authentication secrets. Generate independent, high-entropy values for production.
# JWT_SECRET is supported only as a legacy seed when the two explicit secrets are absent.
# If all are absent the server boots with secure runtime-only keys, but existing sessions
# become invalid after a restart and tokens cannot be shared across multiple replicas.
ACCESS_TOKEN_SECRET=replace_with_a_random_access_token_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_random_refresh_token_secret
# JWT_SECRET=legacy_random_secret

# Demo auth mode: include OTP in the API response so the client can display it onscreen.
# The OTP is never written to server logs. It currently defaults to true for the demo;
# explicitly set false before a public production launch.
DEMO_AUTH_SHOW_OTP=true

# Delhivery Tracking Push API / Scan Push callback URLs shown in admin courier settings.
# Defaults are derived from API_URL. Override only if Delhivery must use a different public host.
# DELHIVERY_SCAN_PUSH_WEBHOOK_URL=https://api.shiplifi.com/api/webhook/delhivery/scan
# DELHIVERY_DOCUMENT_PUSH_WEBHOOK_URL=https://api.shiplifi.com/api/webhook/delhivery/document
# DELHIVERY_LEGACY_WEBHOOK_URL=https://api.shiplifi.com/api/webhook/delhivery/order

# Shopify OAuth app credentials from the Shopify Dev Dashboard.
# Add this exact redirect URL in Shopify:
#   https://api.shiplifi.com/api/integrations/shopify/oauth/callback
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_EXPECTED_CLIENT_ID=your_shopify_client_id
SHOPIFY_INSTALL_AUDIT_LOG_PATH=logs/shopify-install-audit.jsonl
SHOPIFY_BOOTSTRAP_SECRET=optional_shared_secret_for_public_install_bootstrap
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders
SHOPIFY_API_VERSION=2026-04
SHOPIFY_OAUTH_SUCCESS_URL=https://app.shiplifi.com/channels/connected
SHOPIFY_USE_EXPIRING_OFFLINE_TOKENS=true
# Leave false when scopes are managed in the Shopify Dev Dashboard app version.
SHOPIFY_SEND_OAUTH_SCOPE=false
# Shopify App Store subscriptions live in courier-cart-client/shopify.app.toml.
# Add the compliance webhook URI there with compliance_topics:
#   customers/data_request, customers/redact, shop/redact

# Optional emergency-only fallback. Leave disabled for the new OAuth workflow.
SHOPIFY_ALLOW_LEGACY_MANUAL_AUTH=false

# Optional shared fallback secret for WooCommerce webhook HMAC verification.
# The backend generates a per-store secret during connection when this is omitted.
# WOOCOMMERCE_WEBHOOK_SECRET=

# Optional timeout for Shopify/WooCommerce/Magento/Wix platform API calls.
PLATFORM_API_TIMEOUT_MS=15000

# Optional local-only variables for the WooCommerce credential checker.
# Do not commit real merchant credentials.
# WOOCOMMERCE_STORE_URL=https://yourstore.com
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CHECK_WRITE=false

# Email sender identity used by the backend mailers.
# Set this to a verified Shiplifi mailbox in production.
# EMAIL_FROM=noreply@shiplifi.com
# EMAIL_FROM_NAME=Shiplifi
# GOOGLE_SMTP_USER=noreply@shiplifi.com
# GOOGLE_SMTP_PASSWORD=
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
